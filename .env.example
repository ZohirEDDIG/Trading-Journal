# MongoDB Atlas connection string, e.g.:
# mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/trading-journal?retryWrites=true&w=majority
MONGODB_URI=

# Used for absolute URLs if you add server-side fetches later. Safe to leave as-is for local dev.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required by NextAuth to sign session tokens/cookies. Generate one with:
#   npx auth secret
# or:
#   openssl rand -base64 32
AUTH_SECRET=
